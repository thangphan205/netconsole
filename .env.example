# Domain
# This would be set to the production domain with an env var on deployment
DOMAIN=localhost

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="NetConsole"
STACK_NAME=netconsole

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173,http://localhost.tiangolo.com"
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis
USERS_OPEN_REGISTRATION=False

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

SENTRY_DSN=

# Timezone (IANA format, e.g. Asia/Ho_Chi_Minh, America/New_York, UTC)
# See full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=UTC

# Configure these with your own Docker registry images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# Default Credentials to login network devices
NETWORK_USERNAME = "netconsole"
NETWORK_PASSWORD = "xxx"

# Fernet key for encrypting stored device credentials
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=changethis

# OAuth2 / Social Login (leave blank to disable that provider's button)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_SERVER_URL=https://keycloak.example.com
KEYCLOAK_REALM=netconsole

# WebAuthn / Passkey
# WEBAUTHN_RP_ID must match the domain your frontend is served from (no scheme, no port)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=NetConsole
# Full origin including scheme and port for development
WEBAUTHN_ORIGIN=http://localhost
